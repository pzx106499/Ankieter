@model Ankieter.Models.Survey

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Survey</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
    </dl>
</div>
<hr />

<h3>Opcje odpowiedzi</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (Model.Options != null && Model.Options.Any())
{
    foreach (var option in Model.Options)
    {
        <div style="margin-bottom:10px;">
            <strong>@option.Text</strong>

            <form asp-action="Vote" method="post" style="display:inline;">
                <input type="hidden" name="optionId" value="@option.Id" />
                <button type="submit" class="btn btn-primary btn-sm">
                    Głosuj
                </button>
            </form>

            <span>
                Liczba głosów: @option.Votes.Count
            </span>
        </div>
    }
}
else
{
    <p>Brak opcji dla tej ankiety.</p>
}

<hr />

<h3>Wyniki głosowania</h3>

<canvas id="resultsChart" width="400" height="200"></canvas>

<div>
    @if (User.IsInRole("Ankieter"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a>
        <span>|</span>
    }

    <a asp-action="Index">Back to List</a>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const labels = [
        @foreach (var option in Model.Options)
        {
            @: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(option.Text)),
        }
    ];

    const data = [
        @foreach (var option in Model.Options)
        {
                @: @option.Votes.Count,
        }
    ];

    const ctx = document.getElementById('resultsChart');

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Liczba głosów',
                data: data
            }]
        },
        options: {
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        precision: 0
                    }
                }
            }
        }
    });
</script>
